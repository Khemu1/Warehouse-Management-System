{
  "extends": "../shared/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/src/*"],
      "@auth/*": ["../auth-service/src/*"],
      "@bookings/*": ["../booking-service/src/*"],
      "@events/*": ["../inventory-service/src/*"],
      "@payments/*": ["../payment-service/src/*"]
    },
    "emitDeclarationOnly": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
