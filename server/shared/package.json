{
  "name": "@ticketing/shared",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typeorm": "cross-env NODE_ENV=development typeorm-ts-node-commonjs -d src/config/db/data-source.ts",
    "typeorm:prod": "cross-env NODE_ENV=production typeorm -d dist/shared/src/config/db/data-source.js",
    "migration:run:prod": "cross-env NODE_ENV=production npm run typeorm:prod -- migration:run",
    "migration:run:dev": "npm run typeorm -- migration:run",
    "migration:revert:prod": "cross-env NODE_ENV=production npm run typeorm:prod -- migration:revert",
    "migration:revert:dev": "npm run typeorm -- migration:revert",
    "migration:generate:prod": "cross-env NODE_ENV=production typeorm-ts-node-commonjs -d src/config/db/data-source.prod.ts migration:generate src/migrations/initial-schema",
    "migration:generate:dev": "cross-env NODE_ENV=development npm run typeorm -- migration:generate src/config/db/migrations/migrations",
    "seed:run:dev": "cross-env NODE_ENV=development ts-node src/config/db/run-seeds.ts",
    "seed:run:prod": "cross-env NODE_ENV=production node dist/shared/src/config/db/run-seeds.js",
    "seed:create": "cross-env NODE_ENV=development ts-node src/config/db/create-seed.ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@types/express": "^5.0.6",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/typeorm": "^11.0.3",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "rate-limiter-flexible": "^11.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.26",
    "typeorm-extension": "^3.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
