{
  "extends": "../shared/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/src/*"],
      "@auth/*": ["../auth-service/src/*"],
      "@bookings/*": ["../booking-service/src/*"],
      "@events/*": ["../inventory-service/src/*"],
      "@payments/*": ["../payment-service/src/*"]
    },
    "emitDeclarationOnly": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*",
    "../shared/src/safe-client-proxy.ts",
    "../shared/src/guards/rate-limiter.guard.ts"
, "../shared/src/decorators/rate-limit.decorator.ts"  ],
  "exclude": ["node_modules", "dist", "test"]
}
